# Réseau UR7e
ROBOT_IP=192.168.186.141
UR_TYPE=ur7e
LAUNCH_RVIZ=false

# Caméra : AUTO détecte le flux couleur RealSense YUYV 1280x720.
VIDEO_DEVICE=AUTO
CAMERA_TOPIC=/line_camera
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=15
CAMERA_PIXEL_FORMAT=YUYV
CAMERA_OUTPUT_ENCODING=rgb8

# Fichiers générés localement
CALIBRATION_FILE=$HOME/.ros/ur7e_line_follower/ur7e_calibration.yaml
CAMERA_HOMOGRAPHY_FILE=$HOME/.ros/ur7e_line_follower/camera_wall_homography.yaml

# Géométrie réelle à vérifier sur l'installation
WALL_X_M=1.0
LASER_AXIS=tool_z
LASER_ORIGIN_OFFSET_M=0.0

# Modèle fourni
MODEL_FILE=__ROOT__/models/line_follower_sac.zip

# Détection HSV
BLUE_HSV_LO=[95,55,35]
BLUE_HSV_HI=[145,255,255]
RED_HSV_LO1=[0,35,100]
RED_HSV_HI1=[22,255,255]
RED_HSV_LO2=[155,35,100]
RED_HSV_HI2=[180,255,255]
GREEN_HSV_LO=[38,60,35]
GREEN_HSV_HI=[92,255,255]

# Contrôle et sécurités
CONTROL_MODE=visual_only
RL_WEIGHT=0.0
MIN_KLT_CONFIDENCE=0.20
MAX_SENSOR_AGE_S=1.5
MAX_MGD_CAMERA_DISAGREEMENT_M=0.060
MAX_CROSS_TRACK_M=0.080
MAX_TASK_CONDITION=100.0
MAX_EKF_NIS=25.0

SHADOW_DURATION_S=20.0
MOVE_DURATION_S=45.0
SEGMENT_DURATION_S=0.30
MAX_WALL_SPEED_M_S=0.005
MAX_JOINT_SPEED_RAD_S=0.030
VISUAL_CROSS_TRACK_GAIN=1.2
VISUAL_FORWARD_FRACTION=0.85
MGI_DAMPING=0.015
